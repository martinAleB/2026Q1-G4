frontend/.idea
frontend/*.suo
frontend/*.ntvs*
frontend/*.njsproj
frontend/*.sln
frontend/*.sw?

# Frontend env
frontend/.env
frontend/.env.*

# Frontend agents
frontend/AGENTS.md

# ZIPs created
*.zip
**/*.zip

# Backend (Node & Python)
backend/**/node_modules/
backend/**/__pycache__/

# Terraform
**/terraform.tfvars
**/.terraform/
**/.terraform.lock.hcl
